{
    "name": "psc-acme/service-payment",
    "description": "Package service-payment for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ServicePayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "monolog/monolog": "^3.2.0",
        "guzzlehttp/psr7": "^2.0",
        "psc-acme/manager-user": "^1.0",
        "psc-acme/engine-auth": "^1.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}